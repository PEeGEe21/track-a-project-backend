# Runtime and app owner: backend application team
PORT=5000
NODE_ENV="development"
DEVELOPMENT_START_COMMAND="npm run start:dev"
LOG_LEVEL="info"
APP_URL="https://api.example.com"
RUN_MIGRATIONS_ON_STARTUP=false
DATABASE_LOGGING=false

# Auth owner: backend application team
JWT_ACCESS_TOKEN_SECRET="replace-with-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_TOKEN_SECRET="replace-with-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"
OTP_TTL=600
PASSWORD_RECOVERY_TTL=72
PASSWORD_RECOVERY_EMAIL="support@example.com"
PASSWORD_RECOVERY_URL="https://app.example.com/reset-password"

# Frontend integration owner: frontend and backend teams together
FRONTEND_URL="https://app.example.com"
ADMIN_FRONTEND_URL="https://admin.example.com"
CORS_ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com"
PEER_LINK_MAIN="https://app.example.com"
FE_BASE_URL="https://app.example.com"
LIVEKIT_URL="wss://trackr-example.livekit.cloud"
LIVEKIT_API_KEY="replace-with-livekit-api-key"
LIVEKIT_API_SECRET="replace-with-livekit-api-secret"

# Redis and platform infra owner: platform or operations team
REDIS_ENABLED=false
REDIS_URL="redis://127.0.0.1:6379"
REDIS_PREFIX="trackr"
RATE_LIMIT_DRIVER="memory"
QUEUE_DRIVER="inline"
RATE_LIMIT_DEFAULT_MAX=120
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_INVITE_MAX=10
RATE_LIMIT_INVITE_WINDOW_MS=600000
WS_RATE_LIMIT_MAX=60
WS_RATE_LIMIT_WINDOW_MS=60000
WS_RATE_LIMIT_BURST_MAX=180
WS_RATE_LIMIT_BURST_WINDOW_MS=10000

# Database owner: infrastructure / database team
DATABASE_HOST="127.0.0.1"
DATABASE_PORT=3306
DATABASE_USERNAME="root"
DATABASE_PASSWORD="replace-with-db-password"
DATABASE_NAME="trackr"

# Mail provider owner: platform or operations team
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USERNAME="mailer@example.com"
MAIL_PASSWORD="replace-with-mail-password"
APP_NAME="Trackr"
DEFAULT_FROM_EMAIL="noreply@example.com"

# Storage owner: platform or operations team
STORAGE_DRIVER="supabase"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_BUCKET_NAME="trackr-files"
SUPABASE_KEY="replace-with-supabase-service-role-key"
SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
S3_BUCKET_NAME="trackr-files-local"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_ENDPOINT="http://127.0.0.1:9000"
S3_PUBLIC_BASE_URL="http://127.0.0.1:9000/trackr-files-local"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"
S3_BUCKET_PUBLIC_READ="true"
S3_SIGNED_URL_TTL_SECONDS=3600
